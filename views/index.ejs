    <script>
        function changeProductImage(thumb, src) {
            document.getElementById('mainProductImg').src = src;
            // Remove active class from all
            const thumbs = document.querySelectorAll('.thumb-img');
            thumbs.forEach(t => t.classList.remove('active'));
            // Add to clicked
            thumb.classList.add('active');
        }

        function addToCartAndRedirect(product) {
            let cart = JSON.parse(localStorage.getItem('vedanvi_cart') || '[]');
            const existingItem = cart.find(item => item.id === product.id);
            if (existingItem) {
                existingItem.quantity += 1;
            } else {
                product.quantity = 1;
                cart.push(product);
            }
            localStorage.setItem('vedanvi_cart', JSON.stringify(cart));
            window.location.href = '/cart';
        }

        document.addEventListener('DOMContentLoaded', () => {
            const cart = JSON.parse(localStorage.getItem('vedanvi_cart') || '[]');
            const badge = document.querySelector('.icon-link.cart-icon span');
            if (badge) {
                const totalItems = cart.reduce((sum, i) => sum + i.quantity, 0);
                badge.innerText = totalItems;
                badge.style.display = totalItems > 0 ? 'flex' : 'none';
            }
        });
    </script>


