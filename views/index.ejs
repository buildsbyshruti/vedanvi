    <script>
        // Anshveda Hero Slider
        let avCurrentSlide = 0;
        const avSlides = document.querySelectorAll('.av-slide');
        const avDots = document.querySelectorAll('.av-dot');
        let avSlideTimer;

        function showAvSlide(index) {
            avSlides.forEach((slide, i) => {
                slide.classList.remove('active');
                if (i === index) slide.classList.add('active');
            });
            avDots.forEach((dot, i) => {
                dot.classList.remove('active');
                if (i === index) dot.classList.add('active');
            });
        }

        function goToAvSlide(index) {
            avCurrentSlide = index;
            showAvSlide(avCurrentSlide);
            resetAvTimer();
        }

        function nextAvSlide() {
            avCurrentSlide = (avCurrentSlide + 1) % avSlides.length;
            showAvSlide(avCurrentSlide);
        }

        function nextAvSlideManual() {
            avCurrentSlide = (avCurrentSlide + 1) % avSlides.length;
            showAvSlide(avCurrentSlide);
            resetAvTimer();
        }

        function prevAvSlide() {
            avCurrentSlide = (avCurrentSlide - 1 + avSlides.length) % avSlides.length;
            showAvSlide(avCurrentSlide);
            resetAvTimer();
        }

        function resetAvTimer() {
